{
  "map": "Map010",
  "events": [
    {
      "id": "EV010",
      "page": 0,
      "commands": [
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I have to keep going."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "Someone is still here..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "You... are just a child."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "Um... sorry for intruding."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "No, no. Come in."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "You look like you can barely stand on your own two feet."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I-I can still walk."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "That is not the same thing as being okay."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Sit down."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "You should eat something."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "relieved",
          "text": "I am fine, really."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "You are clearly not."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Eat first. Then you can argue with me."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "relieved",
          "text": "This is good."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Of course it is."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "My Dad made it!"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "That's right, little one."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "That... that really helped."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Good."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "It happened right away."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Happened what?"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "annoyed",
          "text": "The food. It made me feel better so fast. Like magic."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "You were just very hungry, boy."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "I guess..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "relieved",
          "text": "Are you okay, sir?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "No."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "But I am still talking, so I suppose that is something."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "The village ahead... it's gone."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "Gone?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Poison. Waste from the old factory."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "It spread through the ground and the drinking water."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "A factory?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Yes."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "We did not know it was leaking until it was already too late for most of us."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "Then why are there people still here?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Some could not leave. Some did not know where else to go."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "And some of us... stayed too long trying to fix it."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "There is something else in that factory."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "Something else?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "A big thing."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Not like the others."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I do not know what it was... But it was wrong in a way my head did not like."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "\\C[2]Elementor\\C[0]..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Maybe. Whatever you call it."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I locked the main factory door after it started moving."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I did not want it reaching the rest of the village."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "smiling",
          "text": "Did it work?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Not fully."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Some smaller things still got out."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "The Elementa."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "They attacked my family."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "My wife."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "My child."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I tried to stop them. I really, really tried."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "They didn't make it."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I hid a photo of them inside the village."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Please, kid."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Bring it back to me."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I will."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "If you do that for me..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I will give you the key to the factory."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "The factory door..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Yes."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "If something evil still lives in there, then it should not be left alone to grow."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "relieved",
          "text": "Okay. I promise."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "And one more thing. The factory is dark inside."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Find a light before you go in, or that place will swallow you whole."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "relieved",
          "text": "A light... okay. I'll look for one."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "You can rest here for a little while longer before you go."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "relieved",
          "text": "Thank you."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "This place is really, really bad."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Mmm... no... not there..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "The water... don't drink the water..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "Excuse me? Can you hear me?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Don't... don't let it in..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "exhausted",
          "text": "They're still alive... but they're so sick."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "So that is what is left here..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "The stranger said I need a light..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Little lamp... little lamp went into the thin mouth..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "Excuse me. I am not here to hurt you. Do you know where I can find a lantern? Or the stranger's house?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "House is sleeping. Lamp is hiding. Thin mouth under the hill. Too small, too hungry."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "A thin mouth under the hill... maybe a cave opening?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Bring my shiny thing back if it still remembers me."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "relieved",
          "text": "Okay. I will try."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "This gap is really small..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "If Ann were here, she would scold me for trying this."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "Got it. It still works... a little."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Can you fly? Bring me that cloud. It has my shoes."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "Huh?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Cloud took them. Cloud is rude."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "I... do not think I can reach a cloud."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Then do not drink the floor."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "relieved",
          "text": "...Okay. I will remember that."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "If Gin were here... he could probably get that."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "No. I can't risk stepping in. Not now."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "This one..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I found it."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "This is enough. I shouldn't pry anymore."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "Wait... What happened here while I was gone?!"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "No... No, please..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "Hey-! Sir!"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "You... came back..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "relieved",
          "text": "What happened?! You were fine!"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "The food... The water..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "It was... already contaminated."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I did not know."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I thought... I thought it was still safe here."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I am so sorry, boy."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "panicking",
          "text": "No... don't apologize... you were just trying to help me."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "That... that is not enough."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "That... that is why you felt better so fast earlier."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "The poison... it was still in there."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "It just... had not reached you fully yet."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Go."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Take the photo back to him."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "He is waiting for you."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "Okay. Hang in there, please."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "You waited for me..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "They are with you now."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "Please rest easy."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I hope you get to meet them again."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "Somewhere peaceful, away from all this."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "Thank you. I won't let this be for nothing."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "That is where it is..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "The thing that started all of this."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "Shii..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "Are you in there too?"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "This is it."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "No way..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "I just need to stay on my feet... live long enough to get out."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "exhausted",
          "text": "Hah...!"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "Move, move, move!"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I am not done yet! I can't be!"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "Just one more turn..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "Come on..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "Almost there..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "\\FX<FC, hard shake>NOW!\\RX"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "It... it's not here."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "My Shii... it must be farther away."
        },
